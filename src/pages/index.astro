---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Crea, descarga y comparte recibos de pago profesionales en PDF al instante. Sin registros, sin contraseñas y con soporte offline."
    />
    <meta property="og:title" content="CalculaYa | Generador de Recibos de Pago Gratis e Instantáneos" />
    <meta
      property="og:description"
      content="¿Necesitas un comprobante rápido? Entra, llena los datos y descarga tu recibo en PDF en 1 segundo. Gratis y sin registrarte."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://calculaya.online/" />
    <meta name="google-adsense-account" content="ca-pub-1139932991314618">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1139932991314618" crossorigin="anonymous"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "CalculaYa",
        "operatingSystem": "All",
        "applicationCategory": "BusinessApplication",
        "offers": {
          "@type": "Offer",
          "price": "0.00",
          "priceCurrency": "USD"
        },
        "description": "Aplicación web optimizada para la generación inmediata de recibos de pago y comprobantes en formato PDF de forma local y segura."
      }
    </script>
    <title>CalculaYa | Generador de Recibos de Pago Gratis e Instantáneos</title>
  </head>
  <body class="flex min-h-screen flex-col bg-[#f7f7f8] text-[#161713] antialiased">
    <main class="mx-auto grid w-full max-w-[95%] flex-1 grid-cols-1 items-start gap-8 py-4 lg:grid-cols-[300px_1fr_300px] xl:max-w-[1440px]">
      <aside
        class="sticky top-24 hidden h-[600px] w-[300px] items-center justify-center overflow-hidden rounded-lg border border-[#e1e5df] bg-white lg:flex relative"
        data-ad-container
        data-ad-label="Anuncio Patrocinado - 300x600"
        data-ad-format-label="300x600"
      >
        <ins
          class="adsbygoogle block h-[600px] w-[300px]"
          style="display:block"
          data-client="ca-pub-1139932991314618"
          data-ad-client="ca-pub-1139932991314618"
          data-ad-slot="1000000001"
          data-ad-format="auto"
          data-full-width-responsive="false"></ins>
      </aside>

      <div class="min-w-0">
        <header class="mb-4 px-1">
          <p class="text-xs font-semibold uppercase text-[#25636f]">CalculaYa.online</p>
          <h1 class="mt-2 text-3xl font-bold leading-tight text-[#151812] sm:text-4xl">
            Herramientas simples para documentos rapidos
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-[#596154] sm:text-base">
            Genera recibos en PDF desde tu dispositivo y conserva un historial local sin cuentas ni pasos extra.
          </p>
        </header>

        <button
          id="install-app-button"
          class="mb-4 hidden w-full rounded-md border border-[#b9d8cb] bg-[#ecfdf5] px-4 py-3 text-sm font-bold text-[#047857] shadow-sm transition hover:bg-[#d1fae5] focus:outline-none focus:ring-4 focus:ring-[#059669]/20 sm:w-auto"
          type="button"
        >
          📲 Instalar App de Recibos
        </button>

        <div class="my-2 block w-full px-4 text-center lg:hidden">
          <div
            class="relative mx-auto flex h-[50px] w-full max-w-[320px] items-center justify-center overflow-hidden rounded-lg border border-[#e1e5df] bg-white"
            data-ad-container
            data-ad-label="Anuncio Patrocinado - 320x50"
            data-ad-format-label="320x50"
          >
            <ins
              class="adsbygoogle block h-[50px] w-[320px]"
              style="display:block"
              data-client="ca-pub-1139932991314618"
              data-ad-client="ca-pub-1139932991314618"
              data-ad-slot="1000000003"
              data-ad-format="horizontal"
              data-full-width-responsive="false"></ins>
          </div>
        </div>

        <section class="flex flex-col rounded-lg border border-[#dfe4d5] bg-white shadow-sm">
          <div
            class="grid grid-cols-3 gap-1 border-b border-[#e2e5ea] bg-[#eef1f4] p-1"
            role="tablist"
            aria-label="Herramientas de CalculaYa"
          >
            <button
              class="tab-button rounded-md bg-white px-2 py-3 text-center text-xs font-bold text-[#1d2419] shadow-sm transition sm:text-sm"
              type="button"
              role="tab"
              id="tab-documentoya"
              aria-controls="panel-documentoya"
              aria-selected="true"
              data-tab-target="documentoya"
            >
              DocumentoYa
            </button>
            <button
              class="tab-button rounded-md px-2 py-3 text-center text-xs font-bold text-[#66705f] transition hover:bg-white/70 sm:text-sm"
              type="button"
              role="tab"
              id="tab-extractolimpio"
              aria-controls="panel-extractolimpio"
              aria-selected="false"
              data-tab-target="extractolimpio"
            >
              ExtractoLimpio
            </button>
            <button
              class="tab-button rounded-md px-2 py-3 text-center text-xs font-bold text-[#66705f] transition hover:bg-white/70 sm:text-sm"
              type="button"
              role="tab"
              id="tab-preciocontodo"
              aria-controls="panel-preciocontodo"
              aria-selected="false"
              data-tab-target="preciocontodo"
            >
              PrecioConTodo
            </button>
          </div>

          <div class="flex-1 p-4 sm:p-6">
            <section
              class="tab-panel"
              role="tabpanel"
              id="panel-documentoya"
              aria-labelledby="tab-documentoya"
              data-tab-panel="documentoya"
            >
              <div class="grid grid-cols-1 gap-6 md:grid-cols-[1.2fr_0.8fr]">
                <form id="recibo-form" class="space-y-4">
                  <div>
                    <h2 class="text-xl font-bold text-[#151812]">Generar recibo</h2>
                    <p class="mt-1 text-sm leading-6 text-[#66705f]">
                      Completa los datos y descarga un PDF listo para compartir.
                    </p>
                  </div>

                  <label class="block">
                    <span class="text-sm font-semibold text-[#343b2f]">Emisor</span>
                    <input
                      class="mt-2 w-full rounded-md border border-[#cfd7c6] bg-white px-4 py-3 text-base outline-none transition placeholder:text-[#9aa292] focus:border-[#25636f] focus:ring-4 focus:ring-[#25636f]/15"
                      name="emisor"
                      type="text"
                      autocomplete="organization"
                      placeholder="Nombre o negocio"
                      required
                    />
                  </label>

                  <label class="block">
                    <span class="text-sm font-semibold text-[#343b2f]">Cliente</span>
                    <input
                      class="mt-2 w-full rounded-md border border-[#cfd7c6] bg-white px-4 py-3 text-base outline-none transition placeholder:text-[#9aa292] focus:border-[#25636f] focus:ring-4 focus:ring-[#25636f]/15"
                      name="cliente"
                      type="text"
                      autocomplete="name"
                      placeholder="Persona o empresa"
                      required
                    />
                  </label>

                  <label class="block">
                    <span class="text-sm font-semibold text-[#343b2f]">Monto</span>
                    <input
                      class="mt-2 w-full rounded-md border border-[#cfd7c6] bg-white px-4 py-3 text-base outline-none transition placeholder:text-[#9aa292] focus:border-[#25636f] focus:ring-4 focus:ring-[#25636f]/15"
                      name="monto"
                      type="number"
                      min="0"
                      step="0.01"
                      inputmode="decimal"
                      placeholder="0.00"
                      required
                    />
                  </label>

                  <label class="block">
                    <span class="text-sm font-semibold text-[#343b2f]">Concepto</span>
                    <textarea
                      class="mt-2 min-h-28 w-full resize-y rounded-md border border-[#cfd7c6] bg-white px-4 py-3 text-base outline-none transition placeholder:text-[#9aa292] focus:border-[#25636f] focus:ring-4 focus:ring-[#25636f]/15"
                      name="concepto"
                      placeholder="Servicio, producto o detalle del pago"
                      required></textarea>
                  </label>

                  <button
                    id="download-button"
                    class="flex min-h-12 w-full items-center justify-center rounded-md bg-[#243f2b] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#1b3121] focus:outline-none focus:ring-4 focus:ring-[#25636f]/25 disabled:cursor-not-allowed disabled:bg-[#94a18d]"
                    type="submit"
                  >
                    Descargar PDF
                  </button>

                  <p id="form-status" class="min-h-5 text-sm font-medium text-[#25636f]" aria-live="polite"></p>
                </form>

                <section class="rounded-lg border border-[#dfe4d5] bg-[#f9fafb] p-5" aria-labelledby="historial-title">
                  <p class="text-xs font-bold uppercase text-[#25636f]">Historial de recibos emitidos</p>
                  <h2 id="historial-title" class="mt-2 text-lg font-bold text-[#151812]">
                    Últimos comprobantes de pago
                  </h2>
                  <div
                    id="history-empty-state"
                    class="mt-5 rounded-md border border-dashed border-[#cfd7c6] bg-white p-4 text-sm leading-6 text-[#66705f]"
                  >
                    Tu historial aparecerá aquí. Los recibos se guardan de forma segura y privada únicamente en este dispositivo.
                  </div>
                  <ul id="history-list" class="mt-5 hidden space-y-3" aria-label="Últimos recibos emitidos"></ul>
                </section>
              </div>
            </section>

            <section
              class="tab-panel hidden"
              role="tabpanel"
              id="panel-extractolimpio"
              aria-labelledby="tab-extractolimpio"
              data-tab-panel="extractolimpio"
            >
              <div class="grid min-h-[28rem] place-items-center rounded-lg border border-dashed border-[#cfd7c6] bg-[#f9fafb] p-6 text-center">
                <div class="max-w-sm">
                  <p class="text-xs font-bold uppercase text-[#25636f]">ExtractoLimpio</p>
                  <h2 class="mt-3 text-2xl font-bold text-[#151812]">Proximamente</h2>
                  <p class="mt-3 text-sm leading-6 text-[#66705f]">
                    Una vista preparada para ordenar extractos y convertir movimientos en informacion util.
                  </p>
                </div>
              </div>
            </section>

            <section
              class="tab-panel hidden"
              role="tabpanel"
              id="panel-preciocontodo"
              aria-labelledby="tab-preciocontodo"
              data-tab-panel="preciocontodo"
            >
              <div class="grid min-h-[28rem] place-items-center rounded-lg border border-dashed border-[#cfd7c6] bg-[#f9fafb] p-6 text-center">
                <div class="max-w-sm">
                  <p class="text-xs font-bold uppercase text-[#25636f]">PrecioConTodo</p>
                  <h2 class="mt-3 text-2xl font-bold text-[#151812]">Proximamente</h2>
                  <p class="mt-3 text-sm leading-6 text-[#66705f]">
                    Un espacio pensado para calcular precios finales con cargos, costos e impuestos incluidos.
                  </p>
                </div>
              </div>
            </section>
          </div>
        </section>
      </div>

      <aside
        class="sticky top-24 hidden h-[600px] w-[300px] items-center justify-center overflow-hidden rounded-lg border border-[#e1e5df] bg-white lg:flex relative"
        data-ad-container
        data-ad-label="Anuncio Patrocinado - 300x600"
        data-ad-format-label="300x600"
      >
        <ins
          class="adsbygoogle block h-[600px] w-[300px]"
          style="display:block"
          data-client="ca-pub-1139932991314618"
          data-ad-client="ca-pub-1139932991314618"
          data-ad-slot="1000000002"
          data-ad-format="auto"
          data-full-width-responsive="false"></ins>
      </aside>
    </main>

    <footer class="border-t border-[#dfe4d5] bg-white px-4 py-4 text-center text-xs font-semibold text-[#596154]">
      Imaginado y Desarrollado por{' '}
      <a
        class="text-[#25636f] underline-offset-4 hover:underline"
        href="https://josuethacevedo.online"
        target="_blank"
        rel="noopener noreferrer"
      >
        Joe Codex ❤️
      </a>
    </footer>

    <script>
      import { db } from '../lib/db';
      import { generateReciboPDF } from '../lib/pdfGenerator';

      type AdsWindow = Window & {
        adsbygoogle?: unknown[] & {
          push: (config: Record<string, never>) => number;
        };
      };

      type BeforeInstallPromptEvent = Event & {
        prompt: () => Promise<void>;
        userChoice: Promise<{ outcome: 'accepted' | 'dismissed'; platform: string }>;
      };

      type StoredReciboData = {
        emisor: string;
        cliente: string;
        monto: number;
        concepto: string;
        filename?: string;
      };

      const ADSENSE_CLIENT = 'ca-pub-1139932991314618';
      const ADSENSE_SRC = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`;
      let deferredPrompt: BeforeInstallPromptEvent | null = null;

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then(reg => console.log('Service Worker registrado con éxito:', reg.scope))
            .catch(err => console.error('Error al registrar el Service Worker:', err));
        });
      }

      const tabButtons = document.querySelectorAll<HTMLButtonElement>('[data-tab-target]');
      const tabPanels = document.querySelectorAll<HTMLElement>('[data-tab-panel]');
      const form = document.querySelector<HTMLFormElement>('#recibo-form');
      const status = document.querySelector<HTMLParagraphElement>('#form-status');
      const downloadButton = document.querySelector<HTMLButtonElement>('#download-button');
      const installAppButton = document.querySelector<HTMLButtonElement>('#install-app-button');
      const historyEmptyState = document.querySelector<HTMLElement>('#history-empty-state');
      const historyList = document.querySelector<HTMLUListElement>('#history-list');
      const adContainers = document.querySelectorAll<HTMLElement>('[data-ad-container]');

      const setStatus = (message: string, isError = false) => {
        if (!status) return;
        status.textContent = message;
        status.classList.toggle('text-[#9b2f2f]', isError);
        status.classList.toggle('text-[#25636f]', !isError);
      };

      const activateTab = (tabName: string) => {
        tabButtons.forEach((button) => {
          const isActive = button.dataset.tabTarget === tabName;
          button.setAttribute('aria-selected', String(isActive));
          button.classList.toggle('bg-white', isActive);
          button.classList.toggle('text-[#1d2419]', isActive);
          button.classList.toggle('shadow-sm', isActive);
          button.classList.toggle('text-[#66705f]', !isActive);
          button.classList.toggle('hover:bg-white/70', !isActive);
        });

        tabPanels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.tabPanel !== tabName);
        });
      };

      const downloadPDF = (pdfBytes: Uint8Array, filename: string) => {
        const blob = new Blob([pdfBytes], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');

        link.href = url;
        link.download = filename;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      };

      const formatMoney = (amount: number) =>
        new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
        }).format(amount);

      const formatReceiptDate = (date: Date) =>
        new Intl.DateTimeFormat('es-PA', {
          dateStyle: 'medium',
          timeStyle: 'short',
        }).format(date);

      const getStoredReciboData = (data: unknown): StoredReciboData | null => {
        if (!data || typeof data !== 'object') return null;

        const recibo = data as Partial<StoredReciboData>;
        const hasValidData =
          typeof recibo.emisor === 'string' &&
          typeof recibo.cliente === 'string' &&
          typeof recibo.concepto === 'string' &&
          typeof recibo.monto === 'number' &&
          Number.isFinite(recibo.monto);

        if (!hasValidData) return null;

        return {
          emisor: recibo.emisor,
          cliente: recibo.cliente,
          monto: recibo.monto,
          concepto: recibo.concepto,
          filename: typeof recibo.filename === 'string' ? recibo.filename : undefined,
        };
      };

      const renderHistoryItem = (documentId: string, createdAt: Date, recibo: StoredReciboData) => {
        const item = document.createElement('li');
        item.className = 'rounded-md border border-[#dfe4d5] bg-white p-3 shadow-sm';

        const row = document.createElement('div');
        row.className = 'flex items-start justify-between gap-3';

        const content = document.createElement('div');
        content.className = 'min-w-0';

        const title = document.createElement('p');
        title.className = 'truncate text-sm font-bold text-[#151812]';
        title.textContent = `${recibo.cliente} · ${recibo.concepto}`;

        const meta = document.createElement('p');
        meta.className = 'mt-1 text-xs leading-5 text-[#66705f]';
        meta.textContent = formatReceiptDate(createdAt);

        const amount = document.createElement('p');
        amount.className = 'mt-2 text-sm font-bold text-[#25636f]';
        amount.textContent = formatMoney(recibo.monto);

        const button = document.createElement('button');
        button.className = 'btn-redescargar flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-[#cfd7c6] bg-[#f9fafb] text-[#25636f] transition hover:bg-[#eef7f4] focus:outline-none focus:ring-4 focus:ring-[#25636f]/15';
        button.type = 'button';
        button.dataset.id = documentId;
        button.setAttribute('aria-label', `Redescargar recibo de ${recibo.cliente}`);
        button.innerHTML = `
          <svg aria-hidden="true" class="pointer-events-none h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <path d="M7 10l5 5 5-5"></path>
            <path d="M12 15V3"></path>
          </svg>
        `;

        content.append(title, meta, amount);
        row.append(content, button);
        item.append(row);

        return item;
      };

      const loadReceiptHistory = async () => {
        if (!historyList || !historyEmptyState) return;

        const documents = await db.documents
          .orderBy('createdAt')
          .reverse()
          .filter((document) => document.type === 'recibo')
          .limit(5)
          .toArray();

        historyList.replaceChildren();

        documents.forEach((document) => {
          const recibo = getStoredReciboData(document.data);
          if (!recibo) return;
          historyList.append(renderHistoryItem(document.id, new Date(document.createdAt), recibo));
        });

        const hasHistory = historyList.children.length > 0;
        historyList.classList.toggle('hidden', !hasHistory);
        historyEmptyState.classList.toggle('hidden', hasHistory);
      };

      const redownloadReceipt = async (documentId: string) => {
        const savedDocument = await db.documents.get(documentId);
        const recibo = getStoredReciboData(savedDocument?.data);

        if (!savedDocument || !recibo) {
          setStatus('No se pudo encontrar ese recibo en tu historial local.', true);
          return;
        }

        const pdfBytes = await generateReciboPDF(recibo);
        const filename = recibo.filename ?? `recibo-${new Date(savedDocument.createdAt).toISOString().slice(0, 10)}.pdf`;

        downloadPDF(pdfBytes, filename);
        setStatus('Recibo recuperado desde tu historial local.');
      };

      const loadAdSense = () =>
        new Promise<boolean>((resolve) => {
          if (document.querySelector(`script[src="${ADSENSE_SRC}"]`)) {
            resolve(true);
            return;
          }

          const script = document.createElement('script');
          script.async = true;
          script.src = ADSENSE_SRC;
          script.crossOrigin = 'anonymous';
          script.onload = () => resolve(true);
          script.onerror = () => resolve(false);
          document.head.append(script);
        });

      const renderMockAd = (container: HTMLElement) => {
        const adElement = container.querySelector<HTMLElement>('ins.adsbygoogle');
        const existingMock = container.querySelector('[data-mock-ad]');
        const label = container.dataset.adLabel ?? 'Anuncio Patrocinado';
        const formatLabel = container.dataset.adFormatLabel ?? 'Demo';

        if (existingMock) return;
        adElement?.classList.add('hidden');

        container.insertAdjacentHTML('beforeend', `
          <div class="absolute inset-0 flex h-full w-full flex-col items-center justify-center rounded-lg bg-gray-50 px-4 text-center" data-mock-ad>
            <span class="text-xs font-semibold uppercase text-gray-400">Mock Ad</span>
            <span class="mt-1 text-sm font-bold text-gray-500">${label}</span>
            <span class="text-xs text-gray-400">${formatLabel}</span>
          </div>
        `);
      };

      const hasRenderedAd = (container: HTMLElement) => {
        const adElement = container.querySelector<HTMLElement>('ins.adsbygoogle');
        const iframe = container.querySelector('iframe');
        const hasAdStatus = adElement?.getAttribute('data-ad-status') === 'filled';
        const hasVisibleFrame = Boolean(iframe && iframe.getBoundingClientRect().width > 0 && iframe.getBoundingClientRect().height > 0);
        const hasContent = Boolean(adElement?.innerHTML.trim() || hasVisibleFrame);

        return hasAdStatus || hasContent;
      };

      const requestAds = () => {
        const adsWindow = window as AdsWindow;
        adsWindow.adsbygoogle = adsWindow.adsbygoogle ?? [];

        adContainers.forEach((container) => {
          if (container.offsetParent === null) return;

          try {
            adsWindow.adsbygoogle?.push({});
          } catch (error) {
            console.warn('AdSense no respondio para este bloque.', error);
          }
        });
      };

      const initializeAds = () => {
        loadAdSense().then((loaded) => {
          if (loaded) {
            requestAds();
          }
        });

        window.setTimeout(() => {
          adContainers.forEach((container) => {
            if (!hasRenderedAd(container)) {
              renderMockAd(container);
            }
          });
        }, 1500);
      };

      tabButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const tabName = button.dataset.tabTarget;
          if (tabName) activateTab(tabName);
        });
      });

      window.addEventListener('beforeinstallprompt', (event) => {
        event.preventDefault();
        deferredPrompt = event as BeforeInstallPromptEvent;
        installAppButton?.classList.remove('hidden');
      });

      installAppButton?.addEventListener('click', async () => {
        if (!deferredPrompt) return;

        await deferredPrompt.prompt();
        await deferredPrompt.userChoice;
        deferredPrompt = null;
        installAppButton.classList.add('hidden');
      });

      historyList?.addEventListener('click', async (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>('.btn-redescargar');
        const documentId = button?.dataset.id;

        if (!documentId) return;

        button.disabled = true;

        try {
          await redownloadReceipt(documentId);
        } catch (error) {
          console.error(error);
          setStatus('No se pudo redescargar el recibo. Intenta nuevamente.', true);
        } finally {
          button.disabled = false;
        }
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form || !downloadButton) return;

        const formData = new FormData(form);
        const emisor = String(formData.get('emisor') ?? '').trim();
        const cliente = String(formData.get('cliente') ?? '').trim();
        const concepto = String(formData.get('concepto') ?? '').trim();
        const monto = Number(formData.get('monto'));

        if (!emisor || !cliente || !concepto || !Number.isFinite(monto)) {
          setStatus('Completa todos los campos para generar el recibo.', true);
          return;
        }

        downloadButton.disabled = true;
        downloadButton.textContent = 'Generando PDF...';
        setStatus('Preparando descarga...');

        try {
          const createdAt = new Date();
          const id = globalThis.crypto?.randomUUID?.() ?? `${createdAt.getTime()}`;
          const recibo = { emisor, cliente, monto, concepto };
          const pdfBytes = await generateReciboPDF(recibo);
          const filename = `recibo-${createdAt.toISOString().slice(0, 10)}.pdf`;

          downloadPDF(pdfBytes, filename);

          await db.documents.add({
            id,
            module: 'DocumentoYa',
            type: 'recibo',
            createdAt,
            data: {
              ...recibo,
              filename,
            },
          });

          form.reset();
          await loadReceiptHistory();
          setStatus('Recibo descargado y guardado en tu historial local.');
        } catch (error) {
          console.error(error);
          setStatus('No se pudo generar el recibo. Intenta nuevamente.', true);
        } finally {
          downloadButton.disabled = false;
          downloadButton.textContent = 'Descargar PDF';
        }
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initializeAds();
          loadReceiptHistory().catch((error) => console.error('No se pudo cargar el historial local:', error));
        }, { once: true });
      } else {
        initializeAds();
        loadReceiptHistory().catch((error) => console.error('No se pudo cargar el historial local:', error));
      }
    </script>
  </body>
</html>
